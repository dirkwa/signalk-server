{
  "openapi": "3.0.0",
  "info": {
    "version": "0.1.0",
    "title": "BLE API",
    "description": "Signal K BLE Provider API endpoints.  Provides a unified view of BLE devices across multiple providers (local adapters, remote gateways) with advertisement streaming and GATT subscription management.",
    "termsOfService": "http://signalk.org/terms/",
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    }
  },
  "externalDocs": {
    "url": "http://signalk.org/specification/",
    "description": "Signal K specification."
  },
  "servers": [
    {
      "url": "/signalk/v2/api/vessels/self/ble"
    }
  ],
  "tags": [
    {
      "name": "BLE",
      "description": "BLE device and advertisement operations."
    },
    {
      "name": "Provider",
      "description": "Operations to view registered BLE providers."
    },
    {
      "name": "Gateway",
      "description": "ESP32 remote BLE gateway management."
    }
  ],
  "components": {
    "schemas": {
      "BLEDeviceInfo": {
        "type": "object",
        "properties": {
          "mac": { "type": "string", "example": "AA:BB:CC:DD:EE:FF" },
          "name": { "type": "string", "example": "SmartShunt 500A" },
          "rssi": { "type": "number", "example": -52 },
          "lastSeen": {
            "type": "number",
            "description": "Unix timestamp (ms)"
          },
          "connectable": { "type": "boolean" },
          "seenBy": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "providerId": { "type": "string" },
                "rssi": { "type": "number" },
                "lastSeen": { "type": "number" }
              }
            }
          },
          "gattClaimedBy": { "type": "string", "nullable": true }
        }
      },
      "BLEAdvertisement": {
        "type": "object",
        "properties": {
          "mac": { "type": "string" },
          "name": { "type": "string" },
          "rssi": { "type": "number" },
          "manufacturerData": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "serviceData": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "serviceUuids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "providerId": { "type": "string" },
          "timestamp": { "type": "number" },
          "connectable": { "type": "boolean" },
          "txPower": { "type": "number" },
          "addressType": { "type": "string", "enum": ["public", "random"] }
        }
      },
      "GatewayInfo": {
        "type": "object",
        "properties": {
          "gatewayId": { "type": "string", "example": "signalk-ble-gw" },
          "providerId": {
            "type": "string",
            "example": "ble:gateway:signalk-ble-gw"
          },
          "online": { "type": "boolean" },
          "ipAddress": {
            "type": "string",
            "nullable": true,
            "example": "192.168.0.120"
          },
          "mac": {
            "type": "string",
            "nullable": true,
            "example": "F0:24:F9:F5:BD:4E"
          },
          "hostname": {
            "type": "string",
            "nullable": true,
            "example": "signalk-ble-gw"
          },
          "firmware": {
            "type": "string",
            "nullable": true,
            "example": "1.0.0"
          },
          "connectedAt": {
            "type": "number",
            "description": "Unix timestamp (ms) when gateway connected"
          },
          "disconnectedAt": {
            "type": "number",
            "description": "Unix timestamp (ms) when gateway disconnected (offline only)"
          },
          "uptime": {
            "type": "number",
            "description": "Gateway uptime in seconds"
          },
          "freeHeap": {
            "type": "number",
            "description": "Free heap memory in bytes"
          },
          "gattSlots": {
            "type": "object",
            "properties": {
              "total": { "type": "number" },
              "available": { "type": "number" }
            }
          },
          "deviceCount": {
            "type": "number",
            "description": "Number of unique BLE devices seen by this gateway"
          }
        }
      },
      "BLEProviders": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "supportsGATT": { "type": "boolean" },
            "gattSlots": {
              "type": "object",
              "properties": {
                "total": { "type": "number" },
                "available": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "JAUTHENTICATION"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
  "paths": {
    "/": {
      "get": {
        "tags": ["BLE"],
        "summary": "BLE API overview",
        "responses": {
          "200": {
            "description": "API endpoint descriptions"
          }
        }
      }
    },
    "/_providers": {
      "get": {
        "tags": ["Provider"],
        "summary": "List registered BLE providers",
        "responses": {
          "200": {
            "description": "Map of provider IDs to provider info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BLEProviders" }
              }
            }
          }
        }
      }
    },
    "/devices": {
      "get": {
        "tags": ["BLE"],
        "summary": "List all visible BLE devices",
        "description": "Returns all visible devices across all providers, deduplicated by MAC address.  Devices not seen for 120 seconds are pruned.",
        "responses": {
          "200": {
            "description": "Array of BLE device info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/BLEDeviceInfo" }
                }
              }
            }
          }
        }
      }
    },
    "/devices/{mac}": {
      "get": {
        "tags": ["BLE"],
        "summary": "Get a single BLE device",
        "parameters": [
          {
            "name": "mac",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Device MAC address (AA:BB:CC:DD:EE:FF)"
          }
        ],
        "responses": {
          "200": {
            "description": "BLE device info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BLEDeviceInfo" }
              }
            }
          },
          "404": { "description": "Device not found" }
        }
      }
    },
    "/devices/{mac}/gatt": {
      "get": {
        "tags": ["BLE"],
        "summary": "Get GATT claim status for a device",
        "parameters": [
          {
            "name": "mac",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "GATT claim info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "claimedBy": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/gateway/advertisements": {
      "post": {
        "tags": ["Gateway"],
        "summary": "Receive BLE advertisement batch from ESP32 gateway",
        "description": "ESP32 gateways POST advertisement batches to this endpoint. Full path: /signalk/v2/api/ble/gateway/advertisements",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["gateway_id", "devices"],
                "properties": {
                  "gateway_id": { "type": "string" },
                  "devices": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "mac": { "type": "string" },
                        "rssi": { "type": "number" },
                        "name": { "type": "string" },
                        "manufacturer_data": {
                          "type": "object",
                          "additionalProperties": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Accepted" },
          "400": { "description": "Invalid body" }
        }
      }
    },
    "/gateway/ws": {
      "get": {
        "tags": ["Gateway"],
        "summary": "WebSocket GATT command channel for ESP32 gateways",
        "description": "Upgrade to WebSocket for GATT subscribe/data/disconnect messaging. Full path: /signalk/v2/api/ble/gateway/ws"
      }
    },
    "/gateways": {
      "get": {
        "tags": ["Gateway"],
        "summary": "List all registered BLE gateways",
        "description": "Returns online gateways and recently-disconnected gateways (up to 60s after disconnect). Full path: /signalk/v2/api/ble/gateways",
        "responses": {
          "200": {
            "description": "Array of gateway info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/GatewayInfo" }
                }
              }
            }
          }
        }
      }
    },
    "/advertisements": {
      "get": {
        "tags": ["BLE"],
        "summary": "WebSocket stream of BLE advertisements",
        "description": "Upgrade to WebSocket to receive a real-time stream of BLEAdvertisement JSON objects from all registered providers."
      }
    }
  }
}
